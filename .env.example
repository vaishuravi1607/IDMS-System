VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your_deployment_id/exec

# Optional — Firebase HTTPS function CORS allowlist (comma-separated). Also set via:
# firebase functions:config:set idms_allowed_origins="https://YOUR_HOST"
# Uses process.env.IDMS_ALLOWED_ORIGINS in functions/index.js
# IDMS_ALLOWED_ORIGINS=https://YOUR_PROJECT.web.app,https://YOUR_PROJECT.firebaseapp.com
